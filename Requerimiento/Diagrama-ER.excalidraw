    },
    {
      "id": "-RN-zxEFlvPrisQSWtqsp",
      "type": "text",
      "x": 655.5886273909301,
      "y": 3571.47020073824,
      "width": 1176.2591552734375,
      "height": 25,
      "angle": 0,
