      "versionNonce": 1626221942,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780761803581,
      "link": null,
      "locked": false,
      "text": "Indica que el dia cuenta NO con archivos de tipoDocumento \"ACUSE\" y \"BALANCE\", y existen dias a futuro con registros",
