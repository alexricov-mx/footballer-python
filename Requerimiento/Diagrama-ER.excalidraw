      "boundElements": [],
      "updated": 1780761803581,
      "link": null,
      "locked": false,
      "text": "Indica que el dia cuenta con archivos de tipoDocumento \"ACUSE\" y \"BALANCE\"",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Indica que el dia cuenta con archivos de tipoDocumento \"ACUSE\" y \"BALANCE\"",
      "autoResize": true,
